{
    "name": "seal-wallet-mcp-server",
    "version": "0.1.1",
    "description": "MCP server for Seal smart wallet — exposes on-chain wallet operations as AI-agent tools",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "seal-mcp": "dist/index.js"
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts --clean",
        "dev": "tsup src/index.ts --format esm --dts --watch",
        "start": "node dist/index.js",
        "lint": "eslint src/"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "@solana/web3.js": "^1.98.0",
        "bs58": "^6.0.0",
        "seal-wallet-sdk": "^0.1.1",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "eslint": "^9.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.7.0"
    },
    "keywords": [
        "mcp",
        "solana",
        "wallet",
        "ai-agent",
        "smart-wallet",
        "seal"
    ],
    "license": "Apache-2.0",
    "homepage": "https://seal.scrolls.fun",
    "repository": {
        "type": "git",
        "url": "https://github.com/immadominion/seal",
        "directory": "packages/mcp-server"
    },
    "files": [
        "dist"
    ]
}
