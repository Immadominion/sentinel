# Environment variables for seal Backend API
# Copy to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# Solana Network
SOLANA_NETWORK=devnet
# For production, use a private RPC endpoint (e.g., Helius, QuickNode)
SOLANA_RPC_URL=https://api.devnet.solana.com

# seal Program
seal_PROGRAM_ID=EV3TKRVz7pTHpAqBTjP8jmwuvoRBRCpjmVSPHhcMnXqb

# Agent Keypair (for signing session executions)
# Generate with: solana-keygen new -o agent-keypair.json
AGENT_KEYPAIR_PATH=./agent-keypair.json

# CORS (comma-separated origins for production)
CORS_ORIGINS=*
