{
  "name": "@seal-wallet/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Seal smart wallet on Solana",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "docs": "typedoc",
    "codama:generate": "node scripts/generate-clients.mjs"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@codama/renderers-js": "^1.0.0",
    "codama": "^1.5.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "directory": "sdk/seal-ts"
  },
  "files": [
    "dist",
    "src"
  ]
}